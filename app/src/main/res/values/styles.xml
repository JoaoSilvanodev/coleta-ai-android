<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Views">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <style name="CampoDeTextoPadrao" parent="Widget.AppCompat.EditText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:background">@drawable/fundo_edittext</item>
    </style>

    <style name="radiobutton" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="android:textSize">14sp</item>
        <item name="android:paddingStart">4dp</item>
        <item name="android:buttonTint">@color/my_primary</item>
        <item name="colorControlActivated">@color/my_primary</item>

    </style>

    <style name="checkbox">
        <item name="android:textSize">14sp</item>

    </style>

    <style name="Img">
        <item name="android:layout_width">50dp</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:layout_margin">8dp</item>
        <item name="android:padding">8dp</item>
        <item name="android:background">@drawable/fundo_redondo_clicavel</item>
        <item name="android:scaleType">fitCenter</item>
    </style>
    <style name="btn_login">
        <item name="backgroundTint">@color/my_secondary</item>
    </style>

    <style name="BottomNavText" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">14sp</item>
    </style>

</resources>